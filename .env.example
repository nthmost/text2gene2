# text2gene2 configuration — copy to .env and fill in
# Do NOT put comments on the same line as values (pydantic-settings will choke)

# NCBI API key — get one free at https://www.ncbi.nlm.nih.gov/account/
# Without: 3 req/sec limit. With: 10 req/sec.
NCBI_API_KEY=

# Google Programmable Search Engine
# API key from https://console.cloud.google.com/ (Custom Search API)
# CSE IDs from https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_WHITELIST_ID=009155410218757639293:nyh3tdzvfhc
GOOGLE_CSE_SCHEMA_ID=003914143621252222636:-mop04_esug

# Redis
REDIS_URL=redis://localhost:6379/0

# Cache TTLs in seconds
CACHE_TTL_LVG=604800
CACHE_TTL_LITVAR2=86400
CACHE_TTL_CLINVAR=86400
CACHE_TTL_GOOGLE=604800
CACHE_TTL_EUROPEPMC=86400

# VariantValidator public API
VARIANT_VALIDATOR_URL=https://rest.variantvalidator.org
VARIANT_VALIDATOR_GENOME_BUILD=GRCh38
VARIANT_VALIDATOR_RATE_LIMIT=1.5

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
